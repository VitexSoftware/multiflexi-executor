#!/bin/sh
# postinst script for multiflexi-docker
set -e

. /usr/share/debconf/confmodule

# Check if the docker group exists and multiflexi user exists
if getent group docker > /dev/null 2>&1; then
    if getent passwd multiflexi > /dev/null 2>&1; then
        # Ensure multiflexi user is a member of the docker group
        usermod -aG docker multiflexi
    fi
fi


#DEBHELPER#
